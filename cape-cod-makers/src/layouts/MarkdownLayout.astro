---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    pubDate?: string;
    date?: string;
    author?: string;
    image?: string;
  };
}

const { frontmatter } = Astro.props;
const displayDate = frontmatter.pubDate ?? frontmatter.date;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} image={frontmatter.image}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4">{frontmatter.title}</h1>
      {displayDate && (
        <time class="text-gray-500 text-sm" datetime={displayDate}>
          {new Date(displayDate).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric', timeZone: 'America/New_York'
          })}
        </time>
      )}
      {frontmatter.author && (
        <p class="text-gray-600 text-sm mt-1">By {frontmatter.author}</p>
      )}
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
