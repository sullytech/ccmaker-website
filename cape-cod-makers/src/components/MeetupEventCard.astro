---
import { formatDate } from '../utils/formatDate';
import type { MeetupEvent } from '../utils/meetup';

interface Props {
  event: MeetupEvent;
}

const { event } = Astro.props;
const { title, date, location, description, url } = event;
---

<article class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col">
  <time class="text-ccm-blue text-sm font-semibold" datetime={date.toISOString()}>
    {formatDate(date, true)}
  </time>
  <h2 class="text-xl font-bold mt-2 mb-2">
    <a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-ccm-blue transition-colors">
      {title}
    </a>
  </h2>
  <p class="text-gray-600 text-sm flex-1 mb-4 line-clamp-3">{description}</p>
  <p class="text-gray-400 text-xs flex items-center gap-1 mb-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
    {location}
  </p>
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="text-ccm-blue text-sm font-medium hover:underline flex items-center gap-1"
  >
    View on Meetup →
  </a>
</article>
