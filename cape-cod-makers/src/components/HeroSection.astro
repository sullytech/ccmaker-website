---
interface Props {
  heading: string;
  subtext?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  backgroundImage?: string;
}

const { heading, subtext, ctaText, ctaHref, secondaryCtaText, secondaryCtaHref, backgroundImage } = Astro.props;
---

<section
  class="relative bg-ccm-dark text-white py-24 px-4"
  style={backgroundImage ? `background-image: url('${backgroundImage}'); background-size: cover; background-position: center;` : ''}
>
  {backgroundImage && <div class="absolute inset-0 bg-black/55" />}
  <div class="relative max-w-4xl mx-auto text-center">
    <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">{heading}</h1>
    {subtext && (
      <p class="text-xl md:text-2xl text-gray-200 mb-8 max-w-2xl mx-auto leading-relaxed">
        {subtext}
      </p>
    )}
    {(ctaText && ctaHref) || (secondaryCtaText && secondaryCtaHref) ? (
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {ctaText && ctaHref && (
          <a
            href={ctaHref}
            class="inline-block bg-ccm-orange text-white font-semibold px-8 py-3 rounded-lg hover:bg-orange-600 transition-colors"
          >
            {ctaText}
          </a>
        )}
        {secondaryCtaText && secondaryCtaHref && (
          <a
            href={secondaryCtaHref}
            class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-lg hover:bg-white hover:text-ccm-dark transition-colors"
          >
            {secondaryCtaText}
          </a>
        )}
      </div>
    ) : null}
  </div>
</section>
