---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/formatDate';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, pubDate, description, author, tags } = post.data;
---

<article class="border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow flex flex-col">
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.slice(0, 3).map(tag => (
      <span class="text-xs bg-blue-50 text-ccm-blue px-2 py-0.5 rounded-full font-medium">
        {tag}
      </span>
    ))}
  </div>
  <h2 class="text-xl font-bold mb-2">
    <a href={`/blog/${post.slug}`} class="hover:text-ccm-blue transition-colors">
      {title}
    </a>
  </h2>
  <p class="text-gray-600 text-sm flex-1 mb-4">{description}</p>
  <div class="flex items-center justify-between text-xs text-gray-400 mt-auto">
    <span>{author}</span>
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
  </div>
  <a href={`/blog/${post.slug}`} class="mt-4 text-ccm-blue text-sm font-medium hover:underline">
    Read more →
  </a>
</article>
