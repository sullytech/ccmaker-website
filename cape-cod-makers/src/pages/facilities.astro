---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import FacilityCard from '../components/FacilityCard.astro';

import { siteBase as base } from '../utils/siteBase';
const facilityAreas = [
  {
    name: 'CNC & Laser Cutting',
    icon: '✂️',
    description: 'Precision cutting and engraving for wood, plastic, acrylic, and more.',
    items: ['X-Carve CNC Engraver/Cutter', 'Glowforge Laser Cutter'],
  },
  {
    name: '3D Printing',
    icon: '🖨️',
    description: 'Turn your digital designs into physical objects with our FDM printers.',
    items: ['Multiple 3D Printers'],
  },
  {
    name: 'Electronics & Soldering',
    icon: '⚡',
    description: 'Professional electronics workbench for prototyping and assembly.',
    items: ['Advanced Soldering Station', 'Reflow Soldering Oven'],
  },
  {
    name: 'Vinyl & Cutting',
    icon: '🎨',
    description: 'Create decals, stickers, heat transfers, and more.',
    items: ['Cameo Pro Vinyl Cutter'],
  },
  {
    name: 'Robotics & Testing',
    icon: '🤖',
    description: 'Build and test your robots in our dedicated arena.',
    items: ['Combat Robot Test Arena'],
  },
  {
    name: 'Workspace & Connectivity',
    icon: '💻',
    description: 'Everything you need to design, collaborate, and create.',
    items: ['Computer Workstations', 'WiFi Internet', 'Fellow Makers'],
  },
];
---

<BaseLayout
  title="Facilities"
  description="Explore the tools, equipment, and workspace areas available at Cape Cod Makers in Harwich, MA."
>
  <HeroSection
    heading="Our Facilities"
    subtext="Professional tools and shared workspace for every type of maker."
    ctaText="Become a Member"
    ctaHref={`${base}membership`}
  />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">What We Have</h2>
      <!-- TODO: Update this description with actual shop overview from organizers -->
      <p class="text-gray-600 max-w-2xl mx-auto">
        Our space in Harwich is a converted classroom packed with tools for digital
        fabrication, electronics, robotics, and more. Full Members have unlimited access.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {facilityAreas.map(area => (
        <FacilityCard
          name={area.name}
          icon={area.icon}
          description={area.description}
          items={area.items}
        />
      ))}
    </div>
  </section>

  <!-- Safety note -->
  <section class="bg-amber-50 border-y border-amber-200 py-12">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-xl font-bold mb-3 text-amber-900">Safety First</h2>
      <!-- TODO: Update with actual safety policy from organizers -->
      <p class="text-amber-800">
        All new members complete a safety orientation before using major equipment.
        Some tools require additional training. Our experienced members and volunteers
        are always available to help.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-2xl mx-auto px-4 py-16 text-center">
    <h2 class="text-2xl font-bold mb-4">Want to See It in Person?</h2>
    <p class="text-gray-600 mb-6">
      Come to an open house and get a guided tour of all our equipment.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={`${base}events`} class="bg-ccm-blue text-white font-semibold px-8 py-3 rounded-lg hover:bg-blue-700 transition-colors">
        Find an Open House
      </a>
      <a href={`${base}membership`} class="border-2 border-ccm-blue text-ccm-blue font-semibold px-8 py-3 rounded-lg hover:bg-ccm-blue hover:text-white transition-colors">
        View Membership
      </a>
    </div>
  </section>
</BaseLayout>
