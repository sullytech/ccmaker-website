---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <p class="text-6xl font-bold text-ccm-blue mb-4">404</p>
    <h1 class="text-3xl font-bold mb-4">Page Not Found</h1>
    <p class="text-gray-600 mb-8">
      Sorry, we couldn't find the page you're looking for. It may have moved or no longer exists.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="bg-ccm-blue text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors"
      >
        Go Home
      </a>
      <a
        href="/events"
        class="border border-ccm-blue text-ccm-blue px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors"
      >
        See Events
      </a>
    </div>
  </section>
</BaseLayout>
