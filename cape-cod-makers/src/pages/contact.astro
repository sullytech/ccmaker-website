---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Cape Cod Makers — we'd love to hear from you."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold mb-4">Contact Us</h1>
    <p class="text-gray-600 mb-12 max-w-xl">
      Have a question about membership, events, or our facilities? We'd love to hear from you.
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Contact Form -->
      <div>
        <h2 class="text-2xl font-bold mb-6">Send Us a Message</h2>
        <ContactForm />
      </div>

      <!-- Contact Info -->
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold mb-6">Find Us</h2>
          <address class="not-italic text-gray-700 space-y-3">
            <div>
              <p class="font-semibold text-gray-900">Cape Cod Makers</p>
              <p>204 Sisson Road</p>
              <p>Harwich, MA 02645</p>
            </div>
            <!-- TODO: Verify and update contact email -->
            <div>
              <a href="mailto:info@capecodmakers.org" class="text-ccm-blue hover:underline">
                info@capecodmakers.org
              </a>
            </div>
          </address>

          <a
            href="https://maps.google.com/?q=204+Sisson+Road+Harwich+MA+02645"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-4 bg-ccm-blue text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition-colors text-sm"
          >
            Get Directions
          </a>
        </div>

        <div>
          <h3 class="text-xl font-bold mb-3">Hours</h3>
          <!-- TODO: Add actual open hours from organizers -->
          <p class="text-gray-600">
            Open hours vary. Check our <a href="/events" class="text-ccm-blue hover:underline">Events page</a>
            for upcoming open houses and drop-in times.
          </p>
          <p class="text-gray-600 mt-2">
            Full Members have 24/7 access via key fob.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-bold mb-3">Follow Us</h3>
          <!-- TODO: Replace # with actual social media URLs -->
          <div class="flex gap-4">
            <a
              href="#"
              class="text-gray-600 hover:text-ccm-blue transition-colors"
              rel="noopener noreferrer"
              target="_blank"
              aria-label="Facebook"
            >
              Facebook
            </a>
            <span class="text-gray-300">|</span>
            <a
              href="#"
              class="text-gray-600 hover:text-ccm-blue transition-colors"
              rel="noopener noreferrer"
              target="_blank"
              aria-label="Instagram"
            >
              Instagram
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
