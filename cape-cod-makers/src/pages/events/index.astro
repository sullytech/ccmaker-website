---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MeetupEventCard from '../../components/MeetupEventCard.astro';
import { getMeetupEvents } from '../../utils/meetup';

import { siteBase as base } from '../../utils/siteBase';
const upcoming = await getMeetupEvents();
---

<BaseLayout
  title="Events"
  description="Upcoming workshops, open houses, and community events at Cape Cod Makers in Harwich, MA."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-4xl font-bold">Events</h1>
      <a
        href="https://www.meetup.com/cape-cod-makers/events/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-ccm-blue hover:underline flex items-center gap-1"
      >
        View on Meetup →
      </a>
    </div>
    <p class="text-gray-600 mb-10">
      Workshops, open houses, and community gatherings at Cape Cod Makers.
    </p>

    <section>
      <h2 class="text-2xl font-semibold mb-6">Upcoming Events</h2>
      {upcoming.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {upcoming.map(event => <MeetupEventCard event={event} />)}
        </div>
      ) : (
        <div class="bg-gray-50 rounded-xl p-8 text-center">
          <p class="text-gray-500 mb-4">No upcoming events scheduled at this time.</p>
          <p class="text-gray-400 text-sm">
            Check our <a href="https://www.meetup.com/cape-cod-makers/events/" target="_blank" rel="noopener noreferrer" class="text-ccm-blue hover:underline">Meetup page</a> or <a href={`${base}contact`} class="text-ccm-blue hover:underline">contact us</a> for more information.
          </p>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
