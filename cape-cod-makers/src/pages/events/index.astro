---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const now = new Date();
const sorted = allEvents.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const upcoming = sorted.filter(e => e.data.date >= now);
const past = sorted.filter(e => e.data.date < now).reverse();
---

<BaseLayout
  title="Events"
  description="Upcoming workshops, open houses, and community events at Cape Cod Makers in Harwich, MA."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold mb-4">Events</h1>
    <p class="text-gray-600 mb-10">
      Workshops, open houses, and community gatherings at Cape Cod Makers.
    </p>

    <section>
      <h2 class="text-2xl font-semibold mb-6">Upcoming Events</h2>
      {upcoming.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {upcoming.map(event => <EventCard event={event} />)}
        </div>
      ) : (
        <div class="bg-gray-50 rounded-xl p-8 text-center">
          <p class="text-gray-500 mb-4">No upcoming events scheduled at this time.</p>
          <p class="text-gray-400 text-sm">Check back soon or <a href="/contact" class="text-ccm-blue hover:underline">contact us</a> for more information.</p>
        </div>
      )}
    </section>

    {past.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-semibold mb-6 text-gray-500">Past Events</h2>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 opacity-70">
          {past.map(event => <EventCard event={event} />)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
