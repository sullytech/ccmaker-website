---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteBase as base } from '../utils/siteBase';
---

<BaseLayout
  title="Tools for Sale"
  description="Browse tools and equipment for sale from Cape Cod Makers."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold mb-4">Tools for Sale</h1>

    <!-- TODO: Replace with actual tools-for-sale content from organizers -->
    <p class="text-lg text-gray-700 mb-8">
      From time to time, Cape Cod Makers sells surplus tools and equipment to members
      and the public. Items are priced fairly and proceeds support our makerspace.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-8">
      <h2 class="font-bold text-amber-900 mb-2">Current Inventory</h2>
      <!-- TODO: Add current tools for sale, or replace with a link to a listing platform -->
      <p class="text-amber-800">
        No items are currently listed. Check back soon, or contact us to be notified
        when new items become available.
      </p>
    </div>

    <div class="space-y-4">
      <h2 class="text-2xl font-bold">How It Works</h2>
      <!-- TODO: Update with actual process from organizers -->
      <ol class="list-decimal list-inside space-y-3 text-gray-700">
        <li>Browse available items listed on this page</li>
        <li>Contact us to inquire about a specific item</li>
        <li>Pick up at our Harwich location (or arrange shipping for smaller items)</li>
      </ol>
    </div>

    <div class="mt-10">
      <a
        href={`${base}contact`}
        class="inline-block bg-ccm-blue text-white font-semibold px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors"
      >
        Contact Us About Tools
      </a>
    </div>
  </div>
</BaseLayout>
